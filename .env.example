# Postgres (app DB + pgvector)
POSTGRES_USER=ragapp
POSTGRES_PASSWORD=ragapp
POSTGRES_DB=ragapp

# Backend
DATABASE_URL=postgresql+asyncpg://ragapp:ragapp@localhost:5435/ragapp
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-in-production-at-least-32-chars
JWT_ALGORITHM=HS256
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS='["http://localhost:3000","http://127.0.0.1:3000"]'
CORS_ALLOW_ORIGIN_REGEX='http://(localhost|127\.0\.0\.1|\[::1\])(:\d+)?'

# Ollama (Enterprise-grade local LLM)
# Default: qwen2.5:7b — upgrade to qwen2.5:14b or qwen2.5:32b for higher synthesis quality
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_REASONER=qwen2.5:7b
OLLAMA_MODEL_PLANNER=qwen2.5:7b
OLLAMA_MODEL_EMBED=bge-m3
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_PREDICT=4096

# Langfuse (self-hosted)
LANGFUSE_NEXTAUTH_SECRET=change-me
LANGFUSE_SALT=change-me
LANGFUSE_PUBLIC_KEY=pk-lf-1234567890
LANGFUSE_SECRET_KEY=sk-lf-1234567890

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

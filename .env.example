# Postgres (app DB + pgvector)
POSTGRES_USER=ragapp
POSTGRES_PASSWORD=ragapp
POSTGRES_DB=ragapp

# Backend
JWT_SECRET=change-me-in-production-at-least-32-chars
JWT_ALGORITHM=HS256
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS='["http://localhost:3000","http://127.0.0.1:3000"]'
CORS_ALLOW_ORIGIN_REGEX='http://(localhost|127\.0\.0\.1|\[::1\])(:\d+)?'

# Langfuse (self-hosted)
LANGFUSE_NEXTAUTH_SECRET=change-me
LANGFUSE_SALT=change-me
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

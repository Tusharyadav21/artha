# Postgres (app DB + pgvector)
POSTGRES_USER=ragapp
POSTGRES_PASSWORD=ragapp
POSTGRES_DB=ragapp

# Backend
DATABASE_URL=postgresql+asyncpg://ragapp:ragapp@localhost:5435/ragapp
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-in-production-at-least-32-chars
JWT_ALGORITHM=HS256
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS='["http://localhost:3000","http://127.0.0.1:3000"]'
CORS_ALLOW_ORIGIN_REGEX='http://(localhost|127\.0\.0\.1|\[::1\])(:\d+)?'

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_REASONER=qwen2.5:3b
OLLAMA_MODEL_PLANNER=qwen2.5:3b
OLLAMA_MODEL_EMBED=nomic-embed-text
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=2048

# Langfuse (self-hosted)
LANGFUSE_NEXTAUTH_SECRET=change-me
LANGFUSE_SALT=change-me
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
